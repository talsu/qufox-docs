{
  "name": "qufox-docs",
  "version": "0.0.0",
  "description": "Serve a folder of Obsidian-flavored Markdown as a modern blog, live.",
  "keywords": [
    "markdown",
    "obsidian",
    "blog",
    "documentation",
    "static-site-generator",
    "live-reload"
  ],
  "homepage": "https://github.com/talsu/qufox-docs#readme",
  "bugs": "https://github.com/talsu/qufox-docs/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talsu/qufox-docs.git"
  },
  "license": "MIT",
  "author": "talsu <talsu84@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:design": "node scripts/sync-design.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/hast": "^3.0.5",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.1",
    "@types/picomatch": "^4.0.3",
    "tsdown": "^0.22.11",
    "typescript": "^7.0.2",
    "vfile": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@shikijs/rehype": "^4.3.1",
    "c12": "^3.3.4",
    "chokidar": "^5.0.0",
    "citty": "^0.2.2",
    "defu": "^6.1.7",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "hono": "^4.12.31",
    "mdast-util-find-and-replace": "^3.0.2",
    "mdast-util-to-string": "^4.0.0",
    "open": "^11.0.0",
    "pagefind": "^1.5.2",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.5",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.3.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "bin": {
    "qufox-docs": "dist/cli.js"
  }
}
